includes:
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:
    level: 9
    paths:
        - src
        - config
    tmpDir: build/phpstan
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Laravel's view()->make() returns Contracts\View\View — identical to View\View at runtime
        -
            identifier: return.type
            path: src/Http/Controllers/LogViewerController.php
        # StatsTable::make() returns self which is static-compatible — safe
        -
            identifier: return.type
            path: src/Tables/StatsTable.php
        # recordAction/recordActionDuplicate bare array params
        -
            identifier: missingType.iterableValue
            path: src/Http/Controllers/LogViewerController.php
        # groupBy() key type is int|string in PHPStan's view even after explicit (string) cast
        -
            identifier: return.type
            path: src/Entities/LogEntryCollection.php
        # Laravel 8 non-generic interface ignores
        -
            identifier: generics.notCompatible
        -
            identifier: generics.notGeneric
        # LogCollection::setFilesystem fluid return missing type (Level 9 niche)
        -
            message: '#Method Skywalker\\LogViewer\\Entities\\LogCollection::setFilesystem\(\) return type has no value type specified in iterable type#'
            path: src/Entities/LogCollection.php
